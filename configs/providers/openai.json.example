{
  "provider_id": "openai",
  "adapter_type": "openai",
  "protocol": "responses",
  "api_key_env": "CENTROID_OPENAI_API_KEY",
  "model_env": "CENTROID_OPENAI_MODEL",
  "model": "gpt-4.1-mini",
  "live_enabled": false,
  "capabilities": {
    "text_generation": true,
    "streaming": true,
    "structured_outputs": true,
    "tool_proposals": true,
    "vision": true,
    "responses_api": true,
    "chat_completions": false,
    "provider_managed_conversation_state": false,
    "remote_mcp": true
  },
  "metadata": {
    "remote_mcp": "metadata only; Centroid v0.4.0 does not execute remote MCP"
  }
}
