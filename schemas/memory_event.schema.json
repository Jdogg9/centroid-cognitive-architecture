{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jdogg9/centroid-cognitive-architecture/schemas/memory_event.schema.json",
  "title": "Centroid Memory Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "timestamp", "event_type", "content", "source", "classification"],
  "properties": {
    "event_id": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "event_type": {"type": "string", "minLength": 1},
    "content": {"type": "string"},
    "source": {"type": "string", "minLength": 1},
    "classification": {
      "type": "string",
      "enum": ["working", "event_journal", "long_term", "privileged", "sensory"]
    },
    "provenance": {"type": "string"},
    "redacted": {"type": "boolean", "default": false},
    "metadata": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    }
  }
}

