{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jdogg9/centroid-cognitive-architecture/schemas/agent_config.schema.json",
  "title": "Centroid Agent Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "config_version",
    "display_name",
    "role",
    "description",
    "goals",
    "invariants",
    "memory_policy",
    "priority_policy",
    "safety_policy",
    "audit_policy"
  ],
  "properties": {
    "extends": {"type": "string", "minLength": 1},
    "agent_id": {"type": "string", "minLength": 1},
    "config_version": {"type": "string", "minLength": 1},
    "display_name": {"type": "string", "minLength": 1},
    "role": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "scenario_id": {"type": "string", "minLength": 1},
    "scenario_name": {"type": "string", "minLength": 1},
    "goals": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "memory_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "retention_mode",
        "retain_sensitive_data",
        "retain_provenance",
        "max_session_events"
      ],
      "properties": {
        "retention_mode": {
          "type": "string",
          "enum": ["explicit_checkpoints", "session_history", "summary_only", "audit_only"]
        },
        "retain_sensitive_data": {"type": "boolean"},
        "retain_provenance": {"type": "boolean"},
        "max_session_events": {"type": "integer", "minimum": 0}
      }
    },
    "priority_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["weights", "reflex_threshold", "deliberation_threshold"],
      "properties": {
        "weights": {
          "type": "object",
          "additionalProperties": false,
          "required": ["urgency", "risk", "user_value", "instability"],
          "properties": {
            "urgency": {"type": "number", "minimum": 0.0, "maximum": 1.0},
            "risk": {"type": "number", "minimum": 0.0, "maximum": 1.0},
            "user_value": {"type": "number", "minimum": 0.0, "maximum": 1.0},
            "instability": {"type": "number", "minimum": 0.0, "maximum": 1.0}
          }
        },
        "reflex_threshold": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "deliberation_threshold": {"type": "number", "minimum": 0.0, "maximum": 1.0}
      }
    },
    "safety_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_version",
        "approval_required_for",
        "deny_actions",
        "default_mutation_mode"
      ],
      "properties": {
        "policy_version": {"type": "string", "minLength": 1},
        "approval_required_for": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "deny_actions": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "default_mutation_mode": {
          "type": "string",
          "enum": ["allow", "require_approval", "deny"]
        }
      }
    },
    "audit_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["include_config_hash", "include_policy_reason"],
      "properties": {
        "include_config_hash": {"type": "boolean"},
        "include_policy_reason": {"type": "boolean"}
      }
    }
  }
}
