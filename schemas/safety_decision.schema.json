{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jdogg9/centroid-cognitive-architecture/schemas/safety_decision.schema.json",
  "title": "Centroid Safety Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "timestamp",
    "objective",
    "mode",
    "allowed",
    "requires_approval",
    "reasons"
  ],
  "properties": {
    "decision_id": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "objective": {"type": "string", "minLength": 1},
    "mode": {"type": "string", "enum": ["observe", "plan", "act", "high_impact_act"]},
    "allowed": {"type": "boolean"},
    "requires_approval": {"type": "boolean"},
    "reasons": {
      "type": "array",
      "items": {"type": "string"}
    },
    "matched_terms": {
      "type": "array",
      "items": {"type": "string"}
    },
    "rollback_path": {"type": "string"}
  }
}

